{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hwu12sluedu/MaterialAI-Workbench/schemas/diagnostics.schema.json",
  "title": "MaterialAI Abaqus diagnostic report",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "overall_status",
    "batch_ready",
    "mcp_ready",
    "checks",
    "next_actions",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "created_at": {"type": "string"},
    "overall_status": {"enum": ["ready", "partial", "blocked"]},
    "batch_ready": {"type": "boolean"},
    "mcp_ready": {"type": "boolean"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label", "status", "message", "evidence"],
        "properties": {
          "key": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "warn", "fail", "not_run"]},
          "message": {"type": "string"},
          "evidence": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "artifacts": {
      "type": "object",
      "required": ["report_dir", "json", "markdown"],
      "properties": {
        "report_dir": {"type": "string"},
        "json": {"type": "string"},
        "markdown": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
